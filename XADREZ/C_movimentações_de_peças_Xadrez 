#include <stdio.h>

// --- FUNÇÕES RECURSIVAS ---

// Torre: Move-se apenas para a Direita de forma recursiva
void moverTorre(int casas) {
if (casas <= 0) return;
printf("Direita\n");
moverTorre(casas - 1);
}
// Bispo (Recursivo e com Loops Aninhados): 
// O loop mais externo controla o movimento vertical (Cima), e o interno o horizontal (Direita).
void moverBispo(int casasVerticais, int casasHorizontais) {
for (int v = 0; v < casasVerticais; v++) {
printf("Cima\n");
for (int h = 0; h < casasHorizontais; h++) {
 printf("Direita\n");
        }
    }
}

// Rainha: Move-se para Cima de forma recursiva
void moverRainha(int casas) {
    if (casas <= 0) return;
    printf("Cima\n");
    moverRainha(casas - 1);
}

// --- FUNÇÃO PRINCIPAL ---

int main() {
    // Definição dos valores diretamente no código (conforme requisitos)
    int casasTorre = 5;
    int casasBispoV = 3; // Movimento vertical do Bispo
    int casasBispoH = 3; // Movimento horizontal do Bispo
    int casasRainha = 4;

// --- EXECUÇÃO DA TORRE ---
    printf("--- Movimento da Torre ---\n");
    moverTorre(casasTorre);
    printf("\n");

    // --- EXECUÇÃO DO BISPO ---
    printf("--- Movimento do Bispo ---\n");
    moverBispo(casasBispoV, casasBispoH);
    printf("\n");

    // --- EXECUÇÃO DA RAINHA ---
    printf("--- Movimento da Rainha ---\n");
    moverRainha(casasRainha);
    printf("\n");

    // --- EXECUÇÃO DO CAVALO ---
    // Movimenta em 'L': 2 casas para cima e 1 para a direita
    printf("--- Movimento do Cavalo ---\n");
    
    int movimentoL = 2; // Duas casas para cima
    int passoHorizontal = 1; // Uma casa para a direita
    int casaAtual = 0;

    // Loops complexos com múltiplas variáveis e controle de fluxo
    for (int i = 0, j = 0; i < movimentoL || j < passoHorizontal; i++) {
    if (i < movimentoL) {
    printf("Cima\n");
        }
    // Loop aninhado interno para a horizontal
        for (int k = 0; k < passoHorizontal; k++) {
            if (i == movimentoL - 1) { // Quando atingir o limite vertical, move para a direita
                printf("Direita\n");
            }
        }

        // Condição para pular o fluxo restante ou encerrar
        if (i >= movimentoL && j >= passoHorizontal) {
            break; 
        }
    }

    return 0;
}