#include <stdio.h>

int main() {
// Movimento da Torre: 5 casas para a direita (Exemplo usando 'for')
printf("Movimentando a Torre:\n");
for (int i = 1; i <= 5; i++) {
printf("Direita\n");
}

printf("\n");

// Movimento do Bispo: 5 casas na diagonal superior direita (Exemplo usando 'while')
printf("Movimentando o Bispo:\n");
int j = 1;
while (j <= 5) {
printf("Cima, Direita\n");
j++;
}